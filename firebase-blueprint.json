  "firestore": {
    "members/{memberId}": {
      "schema": "TeamMember",
      "description": "Thành viên Marketing"
    },
    "tasks/{taskId}": {
      "schema": "Task",
      "description": "Công việc Marketing"
    },
    "schedules/{scheduleId}": {
      "schema": "ProductionSchedule",
      "description": "Lịch sản xuất media"
    },
    "campaigns/{campaignId}": {
      "schema": "Campaign",
      "description": "Chiến dịch Marketing"
    },
    "kpis/{kpiId}": {
      "schema": "KpiAssignment",
      "description": "KPI giao cho chuyên viên"
    },
    "reports/{reportId}": {
      "schema": "WorkReport",
      "description": "Báo cáo công việc định kỳ"
    },
    "evaluations/{evaluationId}": {
      "schema": "PersonnelEvaluation",
      "description": "Đánh giá nhân viên"
    },
    "proposals/{proposalId}": {
      "schema": "Proposal",
      "description": "Đề xuất cải tiến"
    },
    "resources/{resourceId}": {
      "schema": "Resource",
      "description": "Tài nguyên Marketing"
    },
    "plans/{planId}": {
      "schema": "WorkPlan",
      "description": "Kế hoạch tuần & tháng"
    }
